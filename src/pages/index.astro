---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Tree Service Boise, ID | Certified Arborists | Boise Tree Pros"
  description="ISA-certified arborists serving Boise, Meridian, Eagle &amp; Nampa. Tree trimming, removal, emergency service &amp; stump grinding. Fully insured. Free estimates — call (986) 202-7387."
  canonical="https://boisetreepro.com/"
  ogTitle="Tree Service Boise, ID | Boise Tree Pros"
  ogDescription="ISA-certified arborists serving Boise &amp; the Treasure Valley. Tree trimming, removal, emergency service &amp; stump grinding. Free estimates."
  ogImage="https://boisetreepro.com/images/og-image.png"
>
  <Fragment slot="head">
<style>
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    @font-face {
      font-family: 'Inter';
      src: local('Segoe UI'), local('Arial');
      font-style: normal;
      font-weight: 300 700;
      font-display: swap;
    }
    @font-face {
      font-family: 'Zilla Slab';
      src: local('Georgia'), local('Times New Roman');
      font-style: normal;
      font-weight: 400 700;
      font-display: swap;
    }
    @font-face {
      font-family: 'Zilla Slab';
      src: local('Georgia'), local('Times New Roman');
      font-style: italic;
      font-weight: 400;
      font-display: swap;
    }
    body { font-family: 'Inter', 'Segoe UI', Arial, sans-serif; color: #363636; background: #fff; margin: 0; }

    /* Noise texture overlay */
    .noise::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/webp;base64,");
      background-repeat: repeat;
      pointer-events: none;
      opacity: 0.06;
      z-index: 1;
    }

    /* Hero fade-in */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.8s cubic-bezier(0.34, 1.2, 0.64, 1) both; }
    .delay-1 { animation-delay: 0.15s; }
    .delay-2 { animation-delay: 0.30s; }
    .delay-3 { animation-delay: 0.45s; }

    /* Nav link hover */
    .nav-link {
      position: relative;
      font-weight: 500;
      font-size: 14px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #363636;
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -3px;
      left: 0; right: 0;
      height: 2px;
      background: #1A531A;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s cubic-bezier(0.34, 1.2, 0.64, 1);
    }
    .nav-link:hover { color: #1A531A; }
    .nav-link:hover::after { transform: scaleX(1); }
    .nav-link:focus-visible { outline: 2px solid #1A531A; outline-offset: 4px; border-radius: 2px; }

    /* Blog dropdown */
    .dropdown-open .blog-dropdown { opacity:1 !important; visibility:visible !important; transform:translateY(0) !important; }
    .dropdown-open svg { transform: rotate(180deg); }
    .areas-open .areas-dropdown { opacity:1 !important; visibility:visible !important; transform:translateY(0) !important; }
    .areas-open svg { transform: rotate(180deg); }

    .dropdown-link { display: flex; align-items: center; padding: 10px 18px; min-height: 48px; font-size: 14px; color: #363636; text-decoration: none; transition: background-color 0.2s, color 0.2s, opacity 0.2s; outline: none; }
    .dropdown-link:hover { background-color: #f5f0eb; color: #1A531A; }
    .dropdown-link:focus-visible { background-color: #f5f0eb; color: #1A531A; box-shadow: inset 2px 0 0 0 #1A531A; }
    .dropdown-link:active { opacity: 0.7; }

    /* Buttons */
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: #1A531A;
      color: #FAF0E6;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 14px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 14px 28px;
      border: 2px solid #1A531A;
      border-radius: 4px;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 14px rgba(26,83,26,0.25), 0 1px 3px rgba(26,83,26,0.15);
    }
    .btn-primary:hover { background: #2A6B2A; box-shadow: 0 6px 20px rgba(26,83,26,0.35); transform: translateY(-1px); }
    .btn-primary:active { transform: translateY(0); box-shadow: 0 2px 8px rgba(26,83,26,0.2); }
    .btn-primary:focus-visible { outline: 2px solid #87CEEB; outline-offset: 3px; }

    .btn-outline-white {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent;
      color: #FAF0E6;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 14px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 12px 28px;
      border: 2px solid rgba(250,240,230,0.7);
      border-radius: 4px;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, border-color 0.2s, transform 0.15s;
    }
    .btn-outline-white:hover { background: rgba(250,240,230,0.15); border-color: #FAF0E6; transform: translateY(-1px); }
    .btn-outline-white:active { transform: translateY(0); }
    .btn-outline-white:focus-visible { outline: 2px solid #87CEEB; outline-offset: 3px; }

    .btn-bark {
      display: inline-flex; align-items: center; gap: 8px;
      background: #8B5A2B;
      color: #FAF0E6;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 14px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 13px 28px;
      border: 2px solid #8B5A2B;
      border-radius: 4px;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 14px rgba(139,90,43,0.25);
    }
    .btn-bark:hover { background: #A06830; box-shadow: 0 6px 20px rgba(139,90,43,0.35); transform: translateY(-1px); }
    .btn-bark:active { transform: translateY(0); }
    .btn-bark:focus-visible { outline: 2px solid #87CEEB; outline-offset: 3px; }

    .btn-cream {
      display: inline-flex; align-items: center; gap: 8px;
      background: #FAF0E6;
      color: #1A531A;
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 14px 32px;
      border: 2px solid #FAF0E6;
      border-radius: 4px;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 4px 14px rgba(0,0,0,0.15);
    }
    .btn-cream:hover { background: #fff; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,0,0,0.2); }
    .btn-cream:active { transform: translateY(0); }
    .btn-cream:focus-visible { outline: 2px solid #87CEEB; outline-offset: 3px; }

    /* Service cards */
    .service-card {
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      padding: 28px 28px 24px;
      display: flex;
      align-items: flex-start;
      gap: 20px;
      transition: transform 0.25s cubic-bezier(0.34,1.2,0.64,1), box-shadow 0.25s;
      cursor: pointer;
    }
    .service-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(26,83,26,0.10), 0 2px 8px rgba(26,83,26,0.06);
    }
    .service-card:active { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(26,83,26,0.08), 0 1px 4px rgba(26,83,26,0.04); }
    .service-card:focus-visible { outline: 2px solid #1A531A; outline-offset: 3px; border-radius: 8px; }
    .service-card .svc-icon {
      flex-shrink: 0;
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .service-card .svc-body { flex: 1; }
    .svc-learn-more {
      display: inline-block;
      margin-top: 14px;
      padding: 6px 18px;
      border: 1.5px solid #363636;
      border-radius: 3px;
      font-family: 'Zilla Slab', Georgia, serif;
      font-size: 14px;
      font-weight: 400;
      font-style: italic;
      color: #363636;
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }
    .svc-learn-more:hover { background: #363636; color: #fff; }
    .svc-learn-more:focus-visible { outline: 2px solid #1A531A; outline-offset: 3px; }
    
    /* Footer Links */
    .footer-link {
      font-size: 14px; color: rgba(250,240,230,0.65); text-decoration: none;
      transition: color 0.2s, opacity 0.2s; outline: none; display: inline-block;
    }
    .footer-link:hover { color: #FAF0E6; }
    .footer-link:focus-visible { outline: 2px solid #87CEEB; outline-offset: 2px; border-radius: 2px; color: #FAF0E6; }
    .footer-link:active { opacity: 0.7; }

    /* Review cards */
    .review-card {
      background: #FAF0E6;
      border-radius: 8px;
      padding: 28px 24px;
      border: 1px solid #e8ddd0;
      box-shadow: 0 2px 8px rgba(139,90,43,0.07), 0 1px 3px rgba(0,0,0,0.04);
    }
    .review-dot {
      width: 48px; height: 48px; border-radius: 50%;
      background: transparent; border: none; cursor: pointer;
      padding: 0; position: relative;
      display: flex; align-items: center; justify-content: center;
    }
    .review-dot::after {
      content: '';
      width: 8px; height: 8px; border-radius: 50%;
      background: #c8bdb0;
      transition: background-color 0.3s, width 0.3s, border-radius 0.3s;
    }
    .review-dot:hover::after { background: #A06830; }
    .review-dot:focus-visible { outline: 2px solid #1A531A; outline-offset: 3px; }
    .active-dot::after { background: #1A531A; width: 24px; border-radius: 4px; }
    .mini-review {
      display: inline-flex; align-items: center; gap: 8px;
      background: #fff; border: 1px solid #e8ddd0; border-radius: 40px;
      padding: 10px 20px; font-size: 13px; color: #555; white-space: nowrap;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
    }
    .mini-review span { font-style: italic; color: #363636; }
    @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    .marquee-outer:hover .marquee-track { animation-play-state: paused; }
    @media (max-width: 640px) {
      .review-slide { padding: 32px 24px !important; }
    }
    .review-arrow {
      width: 44px; height: 44px; border-radius: 50%; background: #fff;
      border: 1px solid #e8ddd0; display: flex; align-items: center; justify-content: center;
      cursor: pointer; color: #363636; outline: none;
      transition: background-color 0.2s, color 0.2s, box-shadow 0.2s, opacity 0.2s;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .review-arrow:hover { background: #1A531A; color: #FAF0E6; box-shadow: 0 4px 16px rgba(26,83,26,0.2); }
    .review-arrow:focus-visible { outline: 2px solid #1A531A; outline-offset: 2px; }
    .review-arrow:active { opacity: 0.8; box-shadow: 0 2px 4px rgba(26,83,26,0.1); }

    /* Gallery items */
    .gallery-item {
      position: relative;
      overflow: hidden;
      border-radius: 6px;
    }
    .gallery-item img {
      width: 100%;
      display: block;
      transition: transform 0.4s cubic-bezier(0.34,1.2,0.64,1);
    }
    .gallery-item:hover img { transform: scale(1.06); }
    .gallery-item .overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(26,83,26,0.55) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .gallery-item:hover .overlay { opacity: 1; }

    /* Section heading decoration */
    .section-tag {
      display: inline-block;
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #8B5A2B;
      margin-bottom: 10px;
    }
    .section-heading {
      font-family: 'Zilla Slab', Georgia, serif;
      font-weight: 700;
      color: #1A531A;
      line-height: 1.1;
      letter-spacing: -0.03em;
    }
    .section-divider {
      width: 100%;
      max-width: 680px;
      height: 1px;
      background: linear-gradient(to right, transparent, #ccc 20%, #ccc 80%, transparent);
      margin: 18px auto 0;
    }

    /* Checklist */
    .check-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 15px;
      line-height: 1.6;
      color: #363636;
    }
    .check-icon {
      flex-shrink: 0;
      width: 20px; height: 20px;
      background: #1A531A;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin-top: 2px;
    }

    /* Form inputs */
    .form-input {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      padding: 13px 16px;
      border: 1.5px solid rgba(250,240,230,0.5);
      border-radius: 4px;
      background: rgba(255,255,255,0.12);
      color: #FAF0E6;
      outline: none;
      transition: border-color 0.2s, background-color 0.2s, box-shadow 0.2s;
      width: 100%;
    }
    .form-input::placeholder { color: rgba(250,240,230,0.55); }
    .form-input:focus { border-color: #87CEEB; background: rgba(255,255,255,0.18); box-shadow: 0 0 0 3px rgba(135,206,235,0.25); }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #FAF0E6; }
    ::-webkit-scrollbar-thumb { background: #1A531A; border-radius: 3px; }

    /* Mobile nav */
    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }
  </style>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": ["TreeService", "LocalBusiness"],
    "name": "Boise Tree Pros",
    "url": "https://boisetreepro.com",
    "telephone": "(986) 202-7387",
    "email": "info@boisetreepros.com",
    "description": "ISA-certified arborists providing tree trimming, removal, emergency service, and stump grinding in Boise and the Treasure Valley.",
    "foundingDate": "2008",
    "priceRange": "$$",
    "image": "https://boisetreepro.com/images/og-image.png",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Boise",
      "addressRegion": "ID",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 43.6150,
      "longitude": -116.2023
    },
    "areaServed": [
      { "@type": "City", "name": "Boise", "addressRegion": "ID" },
      { "@type": "City", "name": "Meridian", "addressRegion": "ID" },
      { "@type": "City", "name": "Eagle", "addressRegion": "ID" },
      { "@type": "City", "name": "Nampa", "addressRegion": "ID" },
      { "@type": "City", "name": "Caldwell", "addressRegion": "ID" }
    ],
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
        "opens": "07:00",
        "closes": "19:00"
      }
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Tree Care Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tree Trimming & Pruning" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tree Removal" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Emergency Tree Service" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Stump Grinding" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tree Health Assessment" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cabling & Bracing" } }
      ]
    }
  }
  </script>
  </Fragment>
<!-- ══════════════════════════════════
     3. HERO
══════════════════════════════════ -->
<section class="noise relative" style="min-height:90vh;min-height:90svh;display:flex;align-items:center;overflow:hidden;background:#0F3010;contain:layout;">
  <!-- Background image -->
  <picture style="position:absolute;inset:0;">
    <source
      type="image/avif"
      srcset="/images/tree-trimming-boise-hero-400.avif 400w, /images/tree-trimming-boise-hero-800.avif 800w, /images/tree-trimming-boise-hero-1600.avif 1600w"
      sizes="100vw"
    >
    <img src="/images/tree-trimming-boise-hero-800.webp" srcset="/images/tree-trimming-boise-hero-400.webp 400w, /images/tree-trimming-boise-hero-800.webp 800w, /images/tree-trimming-boise-hero-1600.webp 1600w" sizes="100vw" alt="" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;mix-blend-mode:multiply;opacity:0.6;" fetchpriority="high" loading="eager" decoding="async" width="1600" height="588">
  </picture>
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent pointer-events-none z-0"></div>
  <!-- Radial gradients -->
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 80% 80% at 20% 50%, rgba(26,83,26,0.65) 0%, transparent 70%), radial-gradient(ellipse 60% 80% at 80% 20%, rgba(15,48,16,0.8) 0%, transparent 60%), linear-gradient(135deg, rgba(15,48,16,0.9) 0%, rgba(26,83,26,0.5) 60%, rgba(15,48,16,0.7) 100%);pointer-events:none;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-24 w-full">
    <div class="max-w-2xl">
      <span class="fade-up inline-block mb-4 px-3 py-1 rounded-full text-xs font-semibold tracking-widest uppercase" style="background:rgba(135,206,235,0.18);color:#87CEEB;border:1px solid rgba(135,206,235,0.3);">ISA Certified · Boise, Idaho</span>
      <h1 class="fade-up delay-1 section-heading text-cream" style="font-size:clamp(42px,7vw,76px);line-height:1.0;margin-bottom:20px;">
        Tree Service<br>in Boise, ID
      </h1>
      <p class="fade-up delay-2" style="font-size:18px;line-height:1.8;color:rgba(250,240,230,0.85);margin-bottom:36px;max-width:480px;">
        Professional tree care for Boise &amp; surrounding areas. From trimming to emergency removal — we keep your trees healthy and your property safe.
      </p>
      <div class="fade-up delay-3 flex flex-wrap gap-4">
        <a href="#contact" class="btn-cream">Get Free Estimate</a>
        <a href="#services" class="btn-outline-white">Our Services</a>
      </div>

      <!-- Trust bar -->
      <div class="fade-up delay-3 flex flex-wrap gap-6 mt-14" style="border-top:1px solid rgba(250,240,230,0.15);padding-top:24px;">
        <div class="text-cream">
          <div style="font-family:'Zilla Slab',Georgia,serif;font-size:28px;font-weight:700;line-height:1;">500+</div>
          <div style="font-size:12px;letter-spacing:0.06em;color:rgba(250,240,230,0.65);text-transform:uppercase;">Jobs Completed</div>
        </div>
        <div style="width:1px;background:rgba(250,240,230,0.2);"></div>
        <div class="text-cream">
          <div style="font-family:'Zilla Slab',Georgia,serif;font-size:28px;font-weight:700;line-height:1;">15+</div>
          <div style="font-size:12px;letter-spacing:0.06em;color:rgba(250,240,230,0.65);text-transform:uppercase;">Years Experience</div>
        </div>
        <div style="width:1px;background:rgba(250,240,230,0.2);"></div>
        <div class="text-cream">
          <div style="font-family:'Zilla Slab',Georgia,serif;font-size:28px;font-weight:700;line-height:1;">100%</div>
          <div style="font-size:12px;letter-spacing:0.06em;color:rgba(250,240,230,0.65);text-transform:uppercase;">Insured & Licensed</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="position:absolute;bottom:28px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;opacity:0.5;">
    <span style="font-size:11px;color:#FAF0E6;letter-spacing:0.1em;text-transform:uppercase;">Scroll</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none" stroke="#FAF0E6" stroke-width="1.5"><rect x="1" y="1" width="14" height="22" rx="7"/><line x1="8" y1="5" x2="8" y2="10" stroke-linecap="round"/></svg>
  </div>
</section>

<!-- ══════════════════════════════════
     4. TREE SERVICES
══════════════════════════════════ -->
<section id="services" style="background:#fff;padding:88px 0;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Heading -->
    <div class="text-center mb-14">
      <span class="section-tag">What We Do</span>
      <h2 class="section-heading" style="font-size:clamp(32px,4vw,46px);margin-bottom:0;">Tree Services</h2>
      <div class="section-divider"></div>
      <p style="max-width:520px;margin:18px auto 0;font-size:16px;line-height:1.8;color:#666;">From routine maintenance to emergency response, our ISA-certified arborists provide expert care for every tree on your property.</p>
    </div>

    <!-- Grid: exactly 3 columns, 2 rows -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:auto auto;gap:20px;position:relative;" class="services-grid">

      <!-- Ground Care -->
      <div class="service-card" tabindex="0">
        <div class="svc-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" viewBox="0 0 24 24" aria-label="Ground care service icon"><path fill="none" stroke="#363636" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 19a4 4 0 0 1-2.24-7.32A3.5 3.5 0 0 1 9 6.03V6a3 3 0 1 1 6 0v.04a3.5 3.5 0 0 1 3.24 5.65A4 4 0 0 1 16 19Zm4 0v3"/></svg>
        </div>
        <div class="svc-body">
          <h3 style="font-family:'Zilla Slab',Georgia,serif;font-weight:700;font-size:20px;color:#1A531A;margin-bottom:8px;font-style:italic;">Ground Care</h3>
