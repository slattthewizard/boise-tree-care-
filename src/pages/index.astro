<script>
  // Review carousel
  let reviewIdx = 0;
  const totalReviews = 5;
  let reviewTimer;

  function updateCarousel() {
    document.getElementById('review-slides').style.transform = 'translateX(-' + (reviewIdx * 100) + '%)';
    document.querySelectorAll('.review-dot').forEach((d, i) => {
      d.classList.toggle('active-dot', i === reviewIdx);
    });
  }

  function moveReview(dir) {
    reviewIdx = (reviewIdx + dir + totalReviews) % totalReviews;
    updateCarousel();
    resetTimer();
  }

  function goToReview(i) {
    reviewIdx = i;
    updateCarousel();
    resetTimer();
  }

  function resetTimer() {
    clearInterval(reviewTimer);
    reviewTimer = setInterval(() => moveReview(1), 5000);
  }

  reviewTimer = setInterval(() => moveReview(1), 5000);

  // Pause on hover
  document.getElementById('review-track').addEventListener('mouseenter', () => clearInterval(reviewTimer));
  document.getElementById('review-track').addEventListener('mouseleave', resetTimer);
</script>
