---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const canonical = post.data.canonical ?? `https://boisetreepro.com/blog/${post.slug}/`;
const ogImage = post.data.ogImage ?? 'https://boisetreepro.com/images/og-image.png';
const title = post.data.metaTitle ?? post.data.title;
const navTitle = post.data.navTitle ?? post.data.title;
const faq = post.data.faq ?? [];

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://boisetreepro.com/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://boisetreepro.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": navTitle, "item": canonical }
  ]
});

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.metaDescription,
  "url": canonical,
  "datePublished": post.data.publishedDate,
  "dateModified": post.data.publishedDate,
  "author": {
    "@type": "Organization",
    "name": "Boise Tree Pros"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Boise Tree Pros",
    "url": "https://boisetreepro.com"
  }
});

const faqSchema = faq.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
}) : null;
---

<Layout
  title={title}
  description={post.data.metaDescription}
  canonical={canonical}
  ogTitle={title}
  ogDescription={post.data.metaDescription}
  ogImage={ogImage}
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={articleSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
</Fragment>

<style is:global>
  /* Article content styles — matches existing blog posts */
  .article-content h2 { font-family: 'Zilla Slab', Georgia, serif; font-weight: 700; font-size: clamp(22px,3vw,30px); color: #1A531A; margin-top: 48px; margin-bottom: 16px; line-height: 1.15; }
  .article-content h3 { font-family: 'Zilla Slab', Georgia, serif; font-weight: 700; font-size: 20px; color: #1A531A; margin-top: 28px; margin-bottom: 8px; }
  .article-content p { font-size: 16px; line-height: 1.8; color: #555; margin-bottom: 16px; }
  .article-content a { color: #8B5A2B; font-weight: 600; text-decoration: none; }
  .article-content a:hover { text-decoration: underline; }
  .article-content ul, .article-content ol { padding-left: 20px; margin-bottom: 20px; }
  .article-content li { font-size: 16px; line-height: 1.8; color: #555; margin-bottom: 8px; }
  .article-content strong { color: #363636; }
  .article-content em { font-style: italic; }
  .article-content hr { border: none; border-top: 1px solid #e8ddd0; margin: 32px 0; }
  .article-content blockquote { border-left: 4px solid #1A531A; margin: 24px 0; padding: 12px 20px; background: #f5f0eb; border-radius: 0 6px 6px 0; font-style: italic; color: #555; }

  /* Tables */
  .article-content table { width: 100%; border-collapse: collapse; margin: 16px 0 24px; font-size: 15px; }
  .article-content th { background: #1A531A; color: #FAF0E6; padding: 12px 16px; text-align: left; font-weight: 600; font-size: 14px; letter-spacing: 0.03em; }
  .article-content td { padding: 12px 16px; border-bottom: 1px solid #e8ddd0; color: #555; }
  .article-content tr:last-child td { border-bottom: none; }
  .article-content tr:nth-child(even) { background: #FAF0E6; }

  /* Style the first ul (the "What you'll learn" list) like a TOC box */
  .article-content > ul:first-of-type {
    background: #FAF0E6;
    border: 1px solid #e8ddd0;
    border-radius: 8px;
    padding: 20px 24px 20px 40px;
    margin-bottom: 32px;
    list-style: none;
  }
  .article-content > ul:first-of-type li {
    padding-left: 16px;
    position: relative;
    font-size: 15px;
    margin-bottom: 8px;
    color: #555;
  }
  .article-content > ul:first-of-type li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    background: #8B5A2B;
    border-radius: 50%;
  }
  .article-content > ul:first-of-type li a { color: #8B5A2B; }

  /* FAQ section — paragraphs with only a strong child = FAQ question */
  .article-content p:has(> strong:only-child) {
    font-family: 'Zilla Slab', Georgia, serif;
    font-size: 18px;
    color: #363636;
    margin-bottom: 6px;
    margin-top: 20px;
  }
  .article-content p:has(> strong:only-child) strong { color: #363636; font-size: inherit; }

  /* Content grid */
  .content-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 64px; align-items: start; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; gap: 40px; } }

  /* Buttons */
  .btn-primary-blog { display: inline-flex; align-items: center; gap: 8px; background: #1A531A; color: #FAF0E6; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 14px; letter-spacing: 0.06em; text-transform: uppercase; padding: 14px 28px; border: 2px solid #1A531A; border-radius: 4px; cursor: pointer; text-decoration: none; transition: background 0.2s, transform 0.15s, box-shadow 0.2s; box-shadow: 0 4px 14px rgba(26,83,26,0.25); }
  .btn-primary-blog:hover { background: #2A6B2A; box-shadow: 0 6px 20px rgba(26,83,26,0.35); transform: translateY(-1px); }
  .btn-bark-blog { display: inline-flex; align-items: center; gap: 8px; background: #8B5A2B; color: #FAF0E6; font-family: 'Inter', sans-serif; font-weight: 600; font-size: 14px; letter-spacing: 0.06em; text-transform: uppercase; padding: 13px 28px; border: 2px solid #8B5A2B; border-radius: 4px; cursor: pointer; text-decoration: none; transition: background 0.2s, transform 0.15s; box-shadow: 0 4px 14px rgba(139,90,43,0.25); }
  .btn-bark-blog:hover { background: #A06830; transform: translateY(-1px); }
</style>

<!-- BREADCRUMB -->
<nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
  <ol style="list-style:none;padding:0;margin:0;display:flex;gap:8px;font-size:13px;color:#888;">
    <li><a href="/" style="color:#8B5A2B;text-decoration:none;">Home</a></li>
    <li>/</li>
    <li><a href="/blog/" style="color:#8B5A2B;text-decoration:none;">Blog</a></li>
    <li>/</li>
    <li style="color:#363636;">{post.data.navTitle ?? post.data.title}</li>
  </ol>
</nav>

<!-- HERO -->
<section style="background:linear-gradient(135deg, #0F3010 0%, #1A531A 60%, #0F3010 100%);padding:64px 0;position:relative;overflow:hidden;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative">
    {post.data.tag && (
      <span class="inline-block mb-3 px-3 py-1 rounded-full text-xs font-semibold tracking-widest uppercase" style="background:rgba(135,206,235,0.18);color:#87CEEB;border:1px solid rgba(135,206,235,0.3);">{post.data.tag}</span>
    )}
    <h1 style="font-family:'Zilla Slab',Georgia,serif;font-weight:700;color:#FAF0E6;line-height:1.1;letter-spacing:-0.01em;font-size:clamp(28px,4vw,48px);margin-bottom:16px;">{post.data.title}</h1>
    {post.data.subtitle && (
      <p style="font-size:18px;line-height:1.7;color:rgba(250,240,230,0.8);max-width:600px;margin-bottom:28px;">{post.data.subtitle}</p>
    )}
    <div style="display:flex;flex-wrap:wrap;gap:16px;">
      <a href="/#contact" class="btn-primary-blog" style="background:#FAF0E6;color:#1A531A;border-color:#FAF0E6;font-weight:700;">Get a Free Estimate</a>
      <a href="tel:+19862027387" class="btn-primary-blog" style="background:transparent;border-color:rgba(250,240,230,0.5);color:#FAF0E6;">Call (986) 202-7387</a>
    </div>
  </div>
</section>

<!-- ARTICLE CONTENT -->
<section style="padding:72px 0;background:#fff;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="content-grid">

      <!-- Main Content -->
      <div class="article-content">
        <Content />
      </div>

      <!-- Sidebar -->
      <aside>
        <div style="background:#FAF0E6;border:1px solid #e8ddd0;border-radius:8px;padding:28px;margin-bottom:24px;">
          <h3 style="font-family:'Zilla Slab',Georgia,serif;font-weight:700;font-size:20px;color:#1A531A;margin-bottom:12px;">Get a Free Estimate</h3>
          <p style="font-size:14px;line-height:1.7;color:#555;margin-bottom:20px;">An ISA-certified arborist will visit your property, assess your trees, and provide a detailed written estimate at no cost.</p>
          <a href="/#contact" class="btn-primary-blog" style="width:100%;justify-content:center;margin-bottom:12px;">Request Estimate</a>
          <a href="tel:+19862027387" class="btn-bark-blog" style="width:100%;justify-content:center;">Call (986) 202-7387</a>
        </div>

        <div style="background:#fff;border:1px solid #e8ddd0;border-radius:8px;padding:28px;">
          <h3 style="font-family:'Zilla Slab',Georgia,serif;font-weight:700;font-size:18px;color:#1A531A;margin-bottom:16px;">Other Blogs</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:12px;">
            <li><a href="/blog/tree-trimming-boise/" style="font-size:14px;color:#8B5A2B;text-decoration:none;font-weight:500;">&#8594; Tree Trimming</a></li>
            <li><a href="/blog/tree-removal-boise/" style="font-size:14px;color:#8B5A2B;text-decoration:none;font-weight:500;">&#8594; Tree Removal</a></li>
            <li><a href="/blog/emergency-tree-service-boise/" style="font-size:14px;color:#8B5A2B;text-decoration:none;font-weight:500;">&#8594; Emergency Tree Service</a></li>
            <li><a href="/blog/stump-grinding-boise/" style="font-size:14px;color:#8B5A2B;text-decoration:none;font-weight:500;">&#8594; Stump Grinding</a></li>
            <li><a href="/blog/" style="font-size:14px;color:#8B5A2B;text-decoration:none;font-weight:500;">&#8594; All Blogs</a></li>
          </ul>
        </div>

        <div style="background:#fff;border:1px solid #e8ddd0;border-radius:8px;padding:28px;margin-top:24px;">
          <h3 style="font-family:'Zilla Slab',Georgia,serif;font-weight:700;font-size:18px;color:#1A531A;margin-bottom:12px;">Service Areas</h3>
          <p style="font-size:14px;line-height:1.7;color:#555;">We provide tree care throughout the Treasure Valley:</p>
          <ul style="padding-left:18px;margin-top:8px;">
            <li style="font-size:14px;color:#555;margin-bottom:4px;">Boise, ID</li>
            <li style="font-size:14px;color:#555;margin-bottom:4px;">Meridian, ID</li>
            <li style="font-size:14px;color:#555;margin-bottom:4px;">Eagle, ID</li>
            <li style="font-size:14px;color:#555;margin-bottom:4px;">Nampa, ID</li>
            <li style="font-size:14px;color:#555;margin-bottom:4px;">Caldwell, ID</li>
          </ul>
        </div>
      </aside>

    </div>
  </div>
</section>

<!-- CTA BANNER -->
<section style="background:linear-gradient(135deg, #1A531A 0%, #2A6B2A 50%, #1A531A 100%);padding:64px 24px;text-align:center;">
  <h2 style="font-family:'Zilla Slab',Georgia,serif;font-size:clamp(26px,4vw,40px);font-weight:700;color:#FAF0E6;margin-bottom:16px;">Need Tree Service in Boise?</h2>
  <p style="font-size:16px;color:rgba(250,240,230,0.8);margin-bottom:28px;max-width:500px;margin-left:auto;margin-right:auto;">Get a free, no-obligation estimate from an ISA-certified arborist. Most estimates scheduled within 48 hours.</p>
  <div style="display:flex;justify-content:center;gap:16px;flex-wrap:wrap;">
    <a href="/#contact" class="btn-primary-blog" style="background:#FAF0E6;color:#1A531A;border-color:#FAF0E6;font-weight:700;">Get Free Estimate</a>
    <a href="tel:+19862027387" class="btn-primary-blog" style="background:transparent;border-color:rgba(250,240,230,0.5);color:#FAF0E6;">Call (986) 202-7387</a>
  </div>
</section>

</Layout>
