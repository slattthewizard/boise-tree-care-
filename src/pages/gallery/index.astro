<nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 sm:px-6 py-4">
  <ol style="list-style:none;padding:0;margin:0;display:flex;gap:8px;font-size:13px;color:#888;">
    <li><a href="/" style="color:#8B5A2B;text-decoration:none;">Home</a></li>
    <li>/</li>
    <li style="color:#363636;">Gallery</li>
  </ol>
</nav>

<!-- ══════════════════════════════════
     PAGE HEADER
══════════════════════════════════ -->
<section style="padding:32px 0 48px;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <span class="section-tag">Our Work</span>
    <h1 class="section-heading" style="font-size:clamp(30px,4.5vw,48px);margin-bottom:14px;">Project Gallery</h1>
    <p style="font-size:16px;line-height:1.7;color:#666;max-width:600px;margin-bottom:32px;">Real work from real jobs across Boise and the Treasure Valley. Every photo is from our crew on-site.</p>

    <!-- Filter buttons -->
    <div style="display:flex;flex-wrap:wrap;gap:8px;" id="filters">
      <button class="filter-btn active" data-filter="all">All Projects</button>
      <button class="filter-btn" data-filter="trimming">Trimming</button>
      <button class="filter-btn" data-filter="removal">Removal</button>
      <button class="filter-btn" data-filter="stump">Stump Grinding</button>
      <button class="filter-btn" data-filter="planting">Planting</button>
      <button class="filter-btn" data-filter="clearing">Lot Clearing</button>
      <button class="filter-btn" data-filter="crew">Our Crew</button>
    </div>
  </div>
</section>

