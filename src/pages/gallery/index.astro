<!-- ══════════════════════════════════
     FOOTER
══════════════════════════════════ -->
<script>
  // Gallery data
  const galleryItems = document.querySelectorAll('.gallery-card');
  const images = [];
  galleryItems.forEach(card => {
    const img = card.querySelector('img');
    const caption = card.querySelector('.card-overlay span');
    images.push({ src: img.dataset.full || img.src, alt: img.alt, caption: caption ? caption.textContent : '' });
  });

  let currentIndex = 0;

  function openLightbox(index) {
    currentIndex = index;
    const lb = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    const cap = document.getElementById('lightbox-caption');
    img.src = images[index].src;
    img.alt = images[index].alt;
    cap.textContent = images[index].caption;
    lb.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    document.getElementById('lightbox').classList.remove('active');
    document.body.style.overflow = '';
  }

  function navLightbox(dir) {
    // Only navigate visible images
    const visible = [];
    galleryItems.forEach((card, i) => {
      if (card.style.display !== 'none') visible.push(i);
    });
    const currentVisible = visible.indexOf(currentIndex);
    const nextVisible = (currentVisible + dir + visible.length) % visible.length;
    openLightbox(visible[nextVisible]);
  }

  // Close on escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navLightbox(-1);
    if (e.key === 'ArrowRight') navLightbox(1);
  });

  // Close on background click
  document.getElementById('lightbox').addEventListener('click', function(e) {
    if (e.target === this) closeLightbox();
  });

  // Filter functionality
  document.getElementById('filters').addEventListener('click', function(e) {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    const filter = btn.dataset.filter;

    // Update active state
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Filter cards
    galleryItems.forEach(card => {
      if (filter === 'all' || card.dataset.category === filter) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  });
</script>
